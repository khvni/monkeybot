{
  "name": "monkeybot",
  "version": "0.1.0",
  "description": "A computer-use agent that users can teach by recording themselves performing tasks.",
  "private": true,
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter './packages/*' run build",
    "build:desktop": "pnpm --filter @monkeybot/desktop run build",
    "build:driver": "cargo build --manifest-path crates/cua-driver-rs/Cargo.toml",
    "dev": "pnpm --filter @monkeybot/desktop run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "tsc --build",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
