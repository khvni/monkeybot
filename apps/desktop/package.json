{
  "name": "@monkeybot/desktop",
  "version": "0.1.0",
  "description": "Electron menu bar app with push-to-talk voice input and text input for monkeybot.",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc --build && pnpm build:renderer && pnpm copy-static",
    "build:renderer": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --format=iife --platform=browser --target=chrome120 --sourcemap",
    "copy-static": "mkdir -p dist/renderer/styles && cp src/renderer/index.html dist/renderer/index.html && cp -r src/renderer/styles dist/renderer/",
    "dev": "pnpm build && electron .",
    "clean": "rm -rf dist out",
    "lint": "tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@monkeybot/monkey-do": "workspace:*",
    "@monkeybot/monkey-say": "workspace:*",
    "@monkeybot/monkey-see": "workspace:*",
    "@monkeybot/orchestrator": "workspace:*",
    "@monkeybot/safety": "workspace:*",
    "@monkeybot/storage": "workspace:*",
    "electron": "^33.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
